{
    "$schema": "https://schema.railway.app/v2.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "services/processor/Dockerfile",
        "dockerfileContext": "services/processor"
    },
    "deploy": {
        "healthcheckPath": "/health",
        "healthcheckTimeout": 10,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5
    }
}
